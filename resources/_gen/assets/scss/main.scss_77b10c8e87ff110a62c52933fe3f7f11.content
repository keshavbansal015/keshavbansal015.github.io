}.sidebar-profile{display:flex;align-items:center;gap:var(--space-4);margin-bottom:var(--space-6)}.sidebar-profile img{width:48px;height:48px;border-radius:var(--radius-2);object-fit:cover;filter:grayscale(.8);transition:filter .25s ease}.sidebar-profile:hover img{filter:grayscale(.4)}.sidebar-profile h2{font-family:var(--font-mono);font-size:var(--fs-6);font-weight:600;line-height:1;letter-spacing:.12em;text-transform:uppercase;color:var(--sidebar-text-hover)}.sidebar-profile p{font-size:var(--fs-6);color:var(--sidebar-text)}.sidebar-nav{flex:1;display:flex;flex-direction:column;gap:var(--space-1)}.sidebar-nav a{display:flex;align-items:center;gap:var(--space-3);padding:var(--space-3)var(--space-4);font-size:var(--fs-4);font-weight:500;color:var(--sidebar-text);text-decoration:none;border-left:2px solid transparent;margin-left:-2px;border-radius:0 var(--radius-2)var(--radius-2)0;transition:background-color .2s ease,color .2s ease}.sidebar-nav a:hover{color:var(--sidebar-text-hover);background-color:var(--sidebar-border)}.sidebar-nav a.active{color:var(--sidebar-text-hover);font-weight:600;border-left-color:var(--sidebar-active-border);background-color:var(--sidebar-active-bg)}.sidebar-footer{margin-top:auto;padding-top:var(--space-6);border-top:1px solid var(--sidebar-border)}.sidebar-social{display:flex;gap:var(--space-4)}.sidebar-social a{font-size:var(--fs-6);font-family:var(--font-mono);font-weight:600;letter-spacing:.1em;color:var(--sidebar-text);text-decoration:none;transition:color .2s ease}.sidebar-social a:hover{color:var(--sidebar-active-border)}.sidebar-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:99;backdrop-filter:blur(4px)}.sidebar-overlay.show{display:block}@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.6;transform:scale(.9)}}@keyframes float{0%,100%{transform:translate(0,0)scale(1)}25%{transform:translate(30px,-30px)scale(1.05)}50%{transform:translate(20px,20px)scale(.95)}75%{transform:translate(-