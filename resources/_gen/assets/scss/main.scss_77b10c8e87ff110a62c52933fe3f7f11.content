der{margin-bottom:var(--space-6)}.page-header h1{font-size:var(--fs-2)}.text-h1{font-size:28px}.hero h1{font-size:32px}.hero-large h1{font-size:clamp(32px,8vw,48px)}.hero-stats{flex-direction:column;gap:var(--space-4)}.hero-actions{flex-direction:column}.projects-grid{grid-template-columns:1fr}.section-header{flex-direction:column;align-items:flex-start;gap:var(--space-2)}article.single-post{padding:var(--space-5)}.site-footer{flex-direction:column;gap:var(--space-3);text-align:center}.btn-primary,.btn-secondary{width:100%}.contact-form{padding:var(--space-4)}.form-group input,.form-group textarea{font-size:16px}.post-meta{flex-direction:column;align-items:flex-start}}@media print{.sidebar,.site-footer,.animated-bg,.grid-pattern{display:none}.main-content{margin-left:0;padding:0}body{background:#fff;color:#000}}